<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.cloverville.controllers.GreenActionController"
            prefWidth="900" prefHeight="700">

    <children>
        <VBox spacing="20" layoutX="20" layoutY="20" prefWidth="860">

            <Label text="Green Action Catalogue"
                   style="-fx-font-size: 26px; -fx-font-weight: bold;"/>

            <HBox spacing="15">
                <Button text="Add Action"    onAction="#onAddAction"    prefWidth="150"/>
                <Button text="Edit Action"   onAction="#onEditAction"   prefWidth="150"/>
                <Button text="Delete Action" onAction="#onDeleteAction" prefWidth="150"/>
            </HBox>

            <ListView fx:id="actionList" prefHeight="300"/>

            <TitledPane text="Action Details" expanded="true">
                <content>
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <HBox spacing="10">
                            <Label text="Name:" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblName" text="-"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Points:" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblPoints" text="-"/>
                        </HBox>
                        <HBox spacing="10">
                            <Label text="Description:" style="-fx-font-weight: bold;"/>
                            <Label fx:id="lblDescription" wrapText="true" text="-"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>

            <HBox alignment="BOTTOM_RIGHT" spacing="15">
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="Save"   onAction="#onSave"   prefWidth="100"/>
            </HBox>

        </VBox>
    </children>
</AnchorPane>
